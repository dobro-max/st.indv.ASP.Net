WHERE Name IN ('Floare Roșie', 'Floare Albastră', 'Floare Galbenă', 'Floare Violetă', 'Floare Albă');
INSERT INTO BouquetProducts (Name, Description, BasePrice, ImageUrl, IsActive)
VALUES
('Buchet de Trandafiri Roșii', 'Un buchet clasic cu 12 trandafiri roșii proaspeți, simbol al dragostei.', 150.00, 'https://imodflowers.ro/wp-content/uploads/buchet-21-trandafiri-rosii.jpg', 1),
('Buchet Mixt de Primăvară', 'Mix de lalele, narcise și frezii în culori vii pentru un cadou vesel.', 120.00, 'https://www.buchetto.ro/cdn/shop/files/WhatsAppImage2026-01-09at12.24.01_2_1024x1024.jpg?v=1767959374', 1),
('Buchet Elegant de Crini', 'Crini albi și verzi pentru ocazii formale sau condoleanțe.', 180.00, 'https://www.floridelux.ro/storage/app/uploads/public/675/6b7/877/thumb_91540_700_0_0_0_auto.jpg', 1),
('Buchet Exotic cu Orhidee', 'Orhidee tropicale și frunze decorative pentru un touch luxos.', 200.00, 'https://moldflowers.md/images/uploads/products/2025-10-14/buchet-cu-crizanteme-orhidei-si-anthurium-1-moldflowers-onpbcmd-onpbc-fitu-wX-644-hX-488.jpg', 1),
('Buchet Romantic cu Roz', 'Trandafiri roz și hortensii pentru aniversări sau zile de naștere.', 140.00, 'https://www.florariairis.ro/static/i/imagini-produse/buchet-101-trandafiri-roz-1458-1.jpg', 1),
('Buchet Sălbatic de Câmp', 'Margarete, maci și flori sălbatice pentru un look natural.', 100.00, 'https://s13emagst.akamaized.net/products/95594/95593304/images/res_e1d3c937c3839eb463d039447766cdb8.jpg', 1),
('Buchet Luxos cu Pioane', 'Pioane pufoase și eucalipt pentru nunți sau evenimente speciale.', 220.00, 'https://i.pinimg.com/474x/b9/b8/0a/b9b80a0200d630c46a2efb73742eb912.jpg', 1),
('Buchet Vesel cu Gerbere', 'Gerbere colorate și verdeață pentru a aduce bucurie în casă.', 110.00, 'https://yesflowers.md/public/products/27/thumbs/82e1bf235765c24e42351161bd75fd7f.jpg', 1);</sql><current_tab id="0"/></tab_sql></sqlb_project>
